---
import App from "@/layouts/App.astro";
import ChallengePage from "@/components/app/challenge/Page";

const userId = Astro.locals.auth?.()?.userId;
if (!userId) return Astro.redirect("/login");
---
<App title="Challenge — Guru Sishya">
  <ChallengePage client:only="react" userId={userId} />
</App>
