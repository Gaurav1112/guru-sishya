            <div class="flex-1"><p class="text-sm font-medium text-foreground">OTP Service Fails During Peak Traffic</p><p class="text-xs text-muted-foreground mt-0.5">SMS Failover · Rate Limiting · Redis TTL · Brute Force Prevention</p></div>
            <span class="shrink-0 text-muted-foreground text-xs">▼</span>
          </summary>
          <div class="px-4 pb-4 pt-2 border-t border-border/20 space-y-3">
            <p class="text-xs text-muted-foreground"><strong class="text-foreground">Root Cause:</strong> Single SMS provider rate-limited or down. No failover. OTP stored in DB — too slow at scale. No brute-force protection → security risk.</p>
            <div class="mermaid text-xs">
sequenceDiagram
  participant U as User
  participant API as OTP Service
  participant R as Redis
  participant P1 as Primary SMS
  participant P2 as Fallback SMS
  U->>API: request OTP
  API->>R: SET otp:&#123;phone&#125; 6-digit TTL=300s
  API->>R: INCR rate:&#123;phone&#125; (max 5/day)
  API->>P1: send SMS
  alt P1 fails
    API->>P2: failover SMS provider
  end
  U->>API: verify OTP
  API->>R: GET otp:&#123;phone&#125; + DEL (one-time)
  API->>R: INCR verify-fail:&#123;phone&#125; (max 3 attempts)
            </div>
            <pre class="text-xs bg-card rounded-lg p-3 overflow-x-auto text-emerald-400 leading-relaxed">public String generateOTP(String phone) &#123;
    // Rate limit: max 5 OTPs per phone per day
    Long count = redis.opsForValue().increment("rate:" + phone);
    if (count == 1) redis.expire("rate:" + phone, 24, HOURS);
    if (count &gt; 5) throw new RateLimitException("Too many OTPs");

    String otp = String.format("%06d", secureRandom.nextInt(1_000_000));
    redis.opsForValue().set("otp:" + phone, otp, 5, MINUTES);

    try &#123; primarySMS.send(phone, otp); &#125;
    catch (Exception e) &#123; fallbackSMS.send(phone, otp); &#125;
    return "OTP sent";
&#125;

public boolean verifyOTP(String phone, String input) &#123;
    // Brute force: max 3 verify attempts
    Long attempts = redis.opsForValue().increment("fail:" + phone);
    if (attempts == 1) redis.expire("fail:" + phone, 5, MINUTES);
    if (attempts &gt; 3) throw new TooManyAttemptsException();

    String stored = redis.opsForValue().getAndDelete("otp:" + phone);
    return stored != null &amp;&amp; stored.equals(input);
&#125;</pre>
