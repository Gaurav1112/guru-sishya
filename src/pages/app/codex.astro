        <button data-cat="JPA/Hibernate" class="cat-btn px-3 py-1.5 rounded-full text-xs font-medium border bg-card/50 text-muted-foreground border-border/30 hover:border-teal/40 transition-colors cursor-pointer">JPA/Hibernate</button>
        <button data-cat="Java Core" class="cat-btn px-3 py-1.5 rounded-full text-xs font-medium border bg-card/50 text-muted-foreground border-border/30 hover:border-teal/40 transition-colors cursor-pointer">Java Core</button>
        <button data-cat="Kafka/Messaging" class="cat-btn px-3 py-1.5 rounded-full text-xs font-medium border bg-card/50 text-muted-foreground border-border/30 hover:border-teal/40 transition-colors cursor-pointer">Kafka/Messaging</button>
        <button data-cat="Leadership" class="cat-btn px-3 py-1.5 rounded-full text-xs font-medium border bg-card/50 text-muted-foreground border-border/30 hover:border-teal/40 transition-colors cursor-pointer">Leadership</button>
