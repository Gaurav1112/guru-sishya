        <button data-cat="API Design" class="cat-btn px-3 py-1.5 rounded-full text-xs font-medium border bg-card/50 text-muted-foreground border-border/30 hover:border-teal/40 transition-colors cursor-pointer">API Design</button>
        <button data-cat="AWS/Cloud" class="cat-btn px-3 py-1.5 rounded-full text-xs font-medium border bg-card/50 text-muted-foreground border-border/30 hover:border-teal/40 transition-colors cursor-pointer">AWS/Cloud</button>
        <button data-cat="Architecture" class="cat-btn px-3 py-1.5 rounded-full text-xs font-medium border bg-card/50 text-muted-foreground border-border/30 hover:border-teal/40 transition-colors cursor-pointer">Architecture</button>
