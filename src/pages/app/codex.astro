<script is:inline src="https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js"></script>
<script is:inline>
  mermaid.initialize({ startOnLoad: true, theme: 'dark', securityLevel: 'loose' });

  // ── Filter logic ────────────────────────────────────────────────────────────
  (function () {
    const items = Array.from(document.querySelectorAll('.question-item'));
    const countEl = document.getElementById('q-count');
    let activeDiff = 'All';
    let activeCat = 'All';
    let searchText = '';

    function applyFilters() {
      let visible = 0;
      items.forEach(function (el) {
        const diff = el.dataset.diff || '';
        const cat = el.dataset.cat || '';
        const text = el.textContent.toLowerCase();
        const matchDiff = activeDiff === 'All' || diff === activeDiff;
        const matchCat = activeCat === 'All' || cat === activeCat;
        const matchSearch = !searchText || text.includes(searchText);
        const show = matchDiff && matchCat && matchSearch;
        el.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      if (countEl) countEl.textContent = visible + ' question' + (visible !== 1 ? 's' : '');
    }

    // Difficulty buttons
    document.querySelectorAll('.diff-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        activeDiff = this.dataset.diff;
        document.querySelectorAll('.diff-btn').forEach(function (b) {
          b.classList.remove('bg-saffron', 'text-white', 'border-saffron');
          b.classList.add('bg-card/50', 'text-muted-foreground', 'border-border/30');
        });
        this.classList.add('bg-saffron', 'text-white', 'border-saffron');
        this.classList.remove('bg-card/50', 'text-muted-foreground', 'border-border/30');
        applyFilters();
      });
    });

    // Category buttons
    document.querySelectorAll('.cat-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        activeCat = this.dataset.cat;
        document.querySelectorAll('.cat-btn').forEach(function (b) {
          b.classList.remove('bg-saffron', 'text-white', 'border-saffron');
          b.classList.add('bg-card/50', 'text-muted-foreground', 'border-border/30');
        });
        this.classList.add('bg-saffron', 'text-white', 'border-saffron');
        this.classList.remove('bg-card/50', 'text-muted-foreground', 'border-border/30');
        applyFilters();
      });
    });

    // Search input
    var searchInput = document.getElementById('q-search');
    if (searchInput) {
      searchInput.addEventListener('input', function () {
        searchText = this.value.toLowerCase().trim();
        applyFilters();
      });
    }

    // Initial count
    applyFilters();
  })();
</script>
