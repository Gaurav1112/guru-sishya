        </summary>
        <div class="p-5 pt-3 border-t border-border/20 space-y-5">
          <div>
            <h3 class="text-sm font-semibold text-red-400 mb-2">Double-Entry Ledger (NEVER single balance column)</h3>
            <pre class="text-xs bg-card rounded-lg p-3 overflow-x-auto text-emerald-400 leading-relaxed">-- WRONG: UPDATE accounts SET balance = balance - 100 WHERE id = ?
-- RIGHT: Insert two ledger rows atomically

CREATE TABLE ledger_entries (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  account_id UUID NOT NULL REFERENCES accounts(id),
  amount NUMERIC(20,4) NOT NULL,  -- positive=credit, negative=debit
  balance_after NUMERIC(20,4),    -- snapshot for fast reads
  transaction_id UUID NOT NULL,
  created_at TIMESTAMPTZ DEFAULT NOW()
);
-- Balance: SELECT SUM(amount) FROM ledger_entries WHERE account_id = ?
-- Every payment = 2 rows: debit sender + credit receiver (same tx)</pre>
          </div>
          <div>
            <h3 class="text-sm font-semibold text-blue-400 mb-2">Outbox Pattern (Exactly-Once Event Publishing)</h3>
            <pre class="text-xs bg-card rounded-lg p-3 overflow-x-auto text-emerald-400 leading-relaxed">-- Same DB transaction:
BEGIN;
  INSERT INTO orders (id, ...) VALUES (...);
  INSERT INTO outbox (id, topic, key, payload, status)
    VALUES (gen_random_uuid(), 'order.created', order_id, '&#123;&#125;', 'PENDING');
COMMIT;
-- Separate publisher (or Debezium CDC):
-- Poll WHERE status='PENDING' ORDER BY created_at LIMIT 100
-- Publish to Kafka with idempotency key = outbox.id
-- UPDATE outbox SET status='PUBLISHED' WHERE id = ?</pre>
          </div>
        </div>
      </details>
