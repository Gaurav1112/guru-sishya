        <button data-cat="Conflict Resolution" class="cat-btn px-3 py-1.5 rounded-full text-xs font-medium border bg-card/50 text-muted-foreground border-border/30 hover:border-teal/40 transition-colors cursor-pointer">Conflict Resolution</button>
