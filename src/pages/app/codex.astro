        <button data-cat="Performance Optimization" class="cat-btn px-3 py-1.5 rounded-full text-xs font-medium border bg-card/50 text-muted-foreground border-border/30 hover:border-teal/40 transition-colors cursor-pointer">Performance Optimization</button>
        <button data-cat="Production Support" class="cat-btn px-3 py-1.5 rounded-full text-xs font-medium border bg-card/50 text-muted-foreground border-border/30 hover:border-teal/40 transition-colors cursor-pointer">Production Support</button>
        <button data-cat="Real-World Scenarios" class="cat-btn px-3 py-1.5 rounded-full text-xs font-medium border bg-card/50 text-muted-foreground border-border/30 hover:border-teal/40 transition-colors cursor-pointer">Real-World Scenarios</button>
        <button data-cat="SQL" class="cat-btn px-3 py-1.5 rounded-full text-xs font-medium border bg-card/50 text-muted-foreground border-border/30 hover:border-teal/40 transition-colors cursor-pointer">SQL</button>
        <button data-cat="Scalability" class="cat-btn px-3 py-1.5 rounded-full text-xs font-medium border bg-card/50 text-muted-foreground border-border/30 hover:border-teal/40 transition-colors cursor-pointer">Scalability</button>
        <button data-cat="Security" class="cat-btn px-3 py-1.5 rounded-full text-xs font-medium border bg-card/50 text-muted-foreground border-border/30 hover:border-teal/40 transition-colors cursor-pointer">Security</button>
