---
import App from "@/layouts/App.astro";
import FeedbackPage from "@/components/app/admin/FeedbackPage";

const userId = Astro.locals.auth?.()?.userId;
if (!userId) return Astro.redirect("/login");
---
<App title="Admin: Feedback — Guru Sishya">
  <FeedbackPage client:only="react" userId={userId} />
</App>
