---
import App from "@/layouts/App.astro";
import SessionPage from "@/components/app/topic/SessionPage";

const userId = Astro.locals.auth?.()?.userId;
if (!userId) return Astro.redirect("/login");
const { id, num } = Astro.params;
---
<App title="Study Session — Guru Sishya">
  <SessionPage client:only="react" topicId={id} sessionNum={num} userId={userId} />
</App>
