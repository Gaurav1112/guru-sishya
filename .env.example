# Upstash Redis — optional, enables persistent rate limiting across deploys
# Create a free database at https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Google OAuth — create credentials at https://console.developers.google.com
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret

NEXTAUTH_URL=http://localhost:1111

# Set to "true" only when Google OAuth is fully configured above.
# When unset or "false", the Sign In button is hidden and auth routes are disabled.
NEXT_PUBLIC_AUTH_ENABLED=false
